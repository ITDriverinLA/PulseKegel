#!/usr/bin/env bash
# pre-commit hook: auto-update blog-content/*.html lastmod dates on commit
#
# For every blog-content/*.html file (excluding index.html) that is STAGED
# for this commit, this hook automatically stamps today's UTC date into:
#   • the <!--lastmod:YYYY-MM-DD--> comment on line 1
#   • the "dateModified" field in the JSON-LD <script> block (if present)
#
# The updated file is re-staged so the commit always contains the correct date.
# No manual date editing is ever required.
#
# Today's date (not the last-commit date) is used here because we are about to
# record a new commit — that is the actual modification date of the content.
# Build-time syncs (scripts/build-blog.js) use the last git commit date instead.
#
# Install via:  ./install-hooks.sh
# Bypass (emergency only): git commit --no-verify

set -euo pipefail

STAGED_BLOG_FILES=$(git diff --cached --name-only --diff-filter=AM | grep '^blog-content/.*\.html$' || true)

if [[ -z "$STAGED_BLOG_FILES" ]]; then
  exit 0
fi

TODAY=$(date -u +%F)   # YYYY-MM-DD in UTC

HOOK_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$HOOK_DIR/.." && pwd)"
SYNC_SCRIPT="$REPO_ROOT/scripts/sync-blog-dates.js"

while IFS= read -r rel; do
  basename="${rel##*/}"
  if [[ "$basename" == "index.html" ]]; then
    continue
  fi

  abs="$REPO_ROOT/$rel"
  if [[ ! -f "$abs" ]]; then
    continue
  fi

  # Pass --date TODAY so the commit is stamped with today's date rather than
  # the previous commit's date (which is what the build-time sync uses).
  node "$SYNC_SCRIPT" --date "$TODAY" "$abs"

  # Re-stage the updated file so the commit contains the correct date
  git add "$rel"
  echo "auto-dated  $rel  →  lastmod:$TODAY"

done <<< "$STAGED_BLOG_FILES"

echo ""
echo "Blog lastmod dates stamped for this commit ($TODAY UTC)."
