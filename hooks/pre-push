#!/usr/bin/env bash
# pre-push hook: two checks before code leaves the machine
#
# 1. Blog date check: runs the blog build in strict mode (BLOG_STRICT=1) so
#    that date errors are caught locally before CI.
#
# 2. Animation lint: runs ESLint across all of client/ to catch raw Easing
#    calls and hardcoded duration/delay values that must instead use the
#    constants in client/constants/animation.ts.
#
# Install via:  ./install-hooks.sh
# Bypass (emergency only): git push --no-verify

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BUILD_SCRIPT="$REPO_ROOT/scripts/build-blog.js"

if [[ ! -f "$BUILD_SCRIPT" ]]; then
  echo "ERROR: blog build script not found at $BUILD_SCRIPT"
  exit 1
fi

echo "pre-push: running blog build in strict mode..."

if BLOG_STRICT=1 node "$BUILD_SCRIPT"; then
  echo "pre-push: blog date check passed."
else
  echo ""
  echo "ERROR: Blog build failed in strict mode — push blocked."
  echo "Fix the date errors above, then push again."
  echo "To bypass in an emergency: git push --no-verify"
  exit 1
fi

# ---------------------------------------------------------------------------
# 2. Animation lint: full client/ sweep
# ---------------------------------------------------------------------------

ESLINT="$REPO_ROOT/node_modules/.bin/eslint"

if [[ ! -x "$ESLINT" ]]; then
  echo "ERROR: eslint not found at $ESLINT — run 'npm install' first."
  exit 1
fi

echo ""
echo "pre-push: running animation lint on client/..."
echo "  Raw Easing calls and hardcoded duration/delay values are not allowed."
echo "  Use the constants defined in client/constants/animation.ts instead."
echo ""

if cd "$REPO_ROOT" && "$ESLINT" client/; then
  echo "pre-push: animation lint passed."
else
  echo ""
  echo "ERROR: ESLint found animation rule violations in client/."
  echo "Fix the issues above, then push again."
  echo "To bypass in an emergency: git push --no-verify"
  exit 1
fi
